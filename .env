# Configurações AWS - Copie este arquivo para .env e preencha os valores
# NÃO commite o arquivo .env com credenciais reais!

# Região AWS (us-east-1 for Glue/Athena)
AWS_REGION=us-east-1

# Nome do bucket S3 (deve ser único globalmente)
S3_BUCKET=pnad-covid-techchallenge3-7399

# Nome do database no Glue Data Catalog
GLUE_DATABASE=pnad_covid_db

# Nome da IAM Role para Glue Jobs
GLUE_ROLE=GlueServiceRole-TechChallenge3

# Nome do Workgroup do Athena
ATHENA_WORKGROUP=techchallenge3

